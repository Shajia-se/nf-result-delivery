params {
  project_folder  = "$PWD"
  result_delivery_output = "result_delivery_output"
  delivery_tag    = null
  delivery_level  = "lean"   // lean | full

  pipelines_root  = "/ictstr01/groups/idc/projects/uhlenhaut/jiang/pipelines"
  samples_master  = "${params.pipelines_root}/nextflow-chipseq/samples_master.csv"

  fastp_out      = "${params.pipelines_root}/nf-fastp/fastp_output"
  bwa_out        = "${params.pipelines_root}/nf-bwa/bwa_output"
  picard_out     = "${params.pipelines_root}/nf-picard/picard_output"
  chipfilter_out = "${params.pipelines_root}/nf-chipfilter/chipfilter_output"
  frip_out       = "${params.pipelines_root}/nf-frip/frip_output"
  idr_out        = "${params.pipelines_root}/nf-idr/idr_output"
  peak_consensus_out = "${params.pipelines_root}/nf-peak-consensus/peak_consensus_output"
  macs3_out      = "${params.pipelines_root}/nf-macs3/macs3_output"
  diffbind_out   = "${params.pipelines_root}/nf-diffbind/diffbind_output"
  deeptools_out  = "${params.pipelines_root}/nf-deeptools-heatmap/deeptools_heatmap_output"
  homer_out      = "${params.pipelines_root}/nf-homer/homer_output"
  chipseeker_out = "${params.pipelines_root}/nf-chipseeker/chipseeker_output"
  bw_out         = "${params.pipelines_root}/nf-bamcoverage/bamcoverage_output/bigwig"
  multiqc_out    = "${params.pipelines_root}/nf-multiqc/multiqc_output"

  container_result_delivery = "/ictstr01/groups/idc/projects/uhlenhaut/jiang/singularity_image/chipfilter-sam-bed.sif"

  cpus   = 1
  memory = '8 GB'
  time   = '2h'
}

profiles {
  local { includeConfig 'configs/local.config' }
  hpc   { includeConfig 'configs/slurm.config' }
}
