process {
  executor = 'slurm'
  queue    = 'cpu_p'
  clusterOptions = '--qos=cpu_normal --nice=10000 --mail-type=END,FAIL --mail-user=sj.hpcnotification@gmail.com'
  container = params.container_result_delivery

  cpus   = params.cpus
  memory = params.memory
  time   = params.time
}

singularity {
  enabled    = true
  autoMounts = true
}
